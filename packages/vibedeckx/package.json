{
  "name": "vibedeckx",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "vibedeckx": "./dist/bin.js"
  },
  "files": [
    "./dist/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node esbuild.config.mjs && chmod +x ./dist/bin.js",
    "dev": "tsc -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "postinstall": "npm rebuild node-pty || echo 'node-pty rebuild failed, PTY features may not work'"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.18",
    "@clerk/backend": "^3.2.0",
    "@clerk/fastify": "^3.1.2",
    "@fastify/static": "^8.2.0",
    "@fastify/websocket": "^11.0.2",
    "@langfuse/otel": "^5.2.0",
    "@openrouter/ai-sdk-provider": "^2.5.1",
    "@opentelemetry/sdk-node": "^0.216.0",
    "@stricli/core": "^1.2.0",
    "ai": "^6.0.77",
    "better-sqlite3": "^11.6.0",
    "fastify": "^5.6.1",
    "fastify-plugin": "^5.1.0",
    "https-proxy-agent": "^7.0.6",
    "node-pty": "^1.2.0-beta.12",
    "open": "^10.1.0",
    "socks-proxy-agent": "^8.0.5",
    "undici": "^7.22.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "playwright-core": "^1.59.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.0",
    "vitest": "^4.0.18"
  }
}
